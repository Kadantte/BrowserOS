{
  "name": "@browseros/server",
  "version": "0.0.88",
  "description": "BrowserOS server",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "browseros-server": "./src/index.ts"
  },
  "scripts": {
    "start": "bun --watch --env-file=.env.development src/index.ts",
    "build": "bun ../../scripts/build/server.ts --target=all",
    "test": "bun run test:core && bun run test:tools && bun run test:cdp && bun run test:integration && bun run test:sdk",
    "test:core": "bun --env-file=.env.development test ./tests/agent && bun --env-file=.env.development test ./tests/api && bun --env-file=.env.development test ./tests/skills && bun --env-file=.env.development test ./tests/browseros-dir.test.ts && bun --env-file=.env.development test ./tests/build.test.ts && bun --env-file=.env.development test ./tests/config.test.ts && bun --env-file=.env.development test ./tests/index.test.ts && bun --env-file=.env.development test ./tests/main.test.ts",
    "test:tools": "bun run test:tools:acl && bun run test:tools:bookmarks && bun run test:tools:dom && bun run test:tools:filesystem && bun run test:tools:history && bun run test:tools:input && bun run test:tools:keyboard && bun run test:tools:navigation && bun run test:tools:observation && bun run test:tools:page-actions && bun run test:tools:response && bun run test:tools:tab-groups && bun run test:tools:windows",
    "test:tools:acl": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/acl-scorer.test.ts",
    "test:tools:bookmarks": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/bookmarks.test.ts",
    "test:tools:dom": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/dom.test.ts",
    "test:tools:filesystem": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/filesystem",
    "test:tools:history": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/history.test.ts",
    "test:tools:input": "bun run test:tools:input:form && bun run test:tools:input:keys && bun run test:tools:input:acl",
    "test:tools:input:form": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/input.test.ts -t 'fill types text into an input|click triggers a button|check and uncheck toggle a checkbox|select_option selects a dropdown value'",
    "test:tools:input:keys": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/input.test.ts -t 'press_key sends a keystroke|press_key Enter fires keypress event|press_key normalizes case-insensitive key names|scroll dispatches without error|hover moves cursor over element'",
    "test:tools:input:acl": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/input.test.ts -t 'applies updated ACL rules on an existing tool context|blocks coordinate-based actions with ACL intent rules|matches site ACLs after navigation with fresh page info'",
    "test:tools:keyboard": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/keyboard.test.ts",
    "test:tools:navigation": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/navigation.test.ts ./tests/tools/navigation-newtab-guard.test.ts",
    "test:tools:observation": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/observation.test.ts",
    "test:tools:page-actions": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/page-actions.test.ts",
    "test:tools:response": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/response.test.ts",
    "test:tools:tab-groups": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/tab-groups.test.ts",
    "test:tools:windows": "bun run test:cleanup && bun --env-file=.env.development test ./tests/tools/windows.test.ts",
    "test:cdp": "bun run test:cleanup && bun --env-file=.env.development test ./tests/browser/backends/cdp.test.ts",
    "test:integration": "bun run test:cleanup && bun --env-file=.env.development test tests/server.integration.test.ts",
    "test:sdk": "bun run test:cleanup && bun --env-file=.env.development test ./tests/sdk/agent-sdk.test.ts",
    "test:cleanup": "./tests/__helpers__/cleanup.sh",
    "typecheck": "tsc --noEmit",
    "devtools": "bunx @ai-sdk/devtools"
  },
  "exports": {
    ".": {
      "types": "./src/rpc.ts",
      "import": "./src/rpc.ts"
    },
    "./agent": {
      "types": "./src/agent/ai-sdk-agent.ts",
      "default": "./src/agent/ai-sdk-agent.ts"
    },
    "./agent/types": {
      "types": "./src/agent/types.ts",
      "default": "./src/agent/types.ts"
    },
    "./agent/errors": {
      "types": "./src/agent/errors.ts",
      "default": "./src/agent/errors.ts"
    },
    "./lib/clients/gateway": {
      "types": "./src/lib/clients/gateway.ts",
      "default": "./src/lib/clients/gateway.ts"
    },
    "./agent/tool-loop": {
      "types": "./src/agent/ai-sdk-agent.ts",
      "default": "./src/agent/ai-sdk-agent.ts"
    },
    "./agent/tool-loop/provider-factory": {
      "types": "./src/agent/provider-factory.ts",
      "default": "./src/agent/provider-factory.ts"
    },
    "./browser": {
      "types": "./src/browser/browser.ts",
      "default": "./src/browser/browser.ts"
    },
    "./browser/backends/cdp": {
      "types": "./src/browser/backends/cdp.ts",
      "default": "./src/browser/backends/cdp.ts"
    },
    "./tools/registry": {
      "types": "./src/tools/registry.ts",
      "default": "./src/tools/registry.ts"
    }
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.62",
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/azure": "^3.0.31",
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/mcp": "^1.0.21",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/provider": "^3.0.8",
    "@browseros-ai/agent-sdk": "workspace:*",
    "@huggingface/transformers": "^3.4.0",
    "@browseros/cdp-protocol": "workspace:*",
    "@browseros/shared": "workspace:*",
    "@google/gemini-cli-core": "^0.16.0",
    "@google/genai": "1.30.0",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.19.6",
    "@hono/zod-validator": "^0.4.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@sentry/bun": "^10.31.0",
    "ai": "^6.0.94",
    "chrome-devtools-frontend": "^1.0.1577886",
    "commander": "^14.0.1",
    "core-js": "3.45.1",
    "debug": "4.4.3",
    "eventsource-parser": "^3.0.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.3",
    "jimp": "^1.6.0",
    "klavis": "^2.15.0",
    "pino": "^9.6.0",
    "posthog-node": "^4.17.0",
    "puppeteer-core": "24.23.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-from-json-schema": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.3.3",
    "@types/sinon": "^21.0.0",
    "@types/ws": "^8.5.13",
    "async-mutex": "^0.5.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "24.23.0",
    "sinon": "^21.0.1",
    "typescript": "^5.9.2"
  },
  "optionalDependencies": {
    "chrome-devtools-mcp": "latest"
  },
  "license": "AGPL-3.0-or-later"
}
